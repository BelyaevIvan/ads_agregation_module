# ── Telegram ───────────────────────────────────────────────────────────────
TG_API_ID=
TG_API_HASH=

# Строковая сессия Telethon (рекомендуется для Docker).
# Сгенерировать: docker compose run --rm --no-deps tg-monitor python auth_tg.py
TG_SESSION_STRING=

# Прокси SOCKS5 (опционально — оставь пустым если не нужен)
TG_PROXY_HOST=
TG_PROXY_PORT=
TG_PROXY_USER=
TG_PROXY_PASS=

# ID каналов/чатов через запятую (отрицательные числа)
TG_WATCHED_CHANNELS=

# ── VK ─────────────────────────────────────────────────────────────────────
VK_ACCESS_TOKEN=
VK_CHECK_INTERVAL=5

# Группы JSON-массивом: [{"id": -225463035, "name": "Название"}]
VK_GROUPS=[]

# ── Ollama ─────────────────────────────────────────────────────────────────
# В Docker эти значения переопределяются через docker-compose environment
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ── MinIO bucket ───────────────────────────────────────────────────────────
MINIO_BUCKET=brandhunt-photos
