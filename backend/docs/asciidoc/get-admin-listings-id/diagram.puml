@startuml activity diagram
:4.1. Идентификация пользователя по JWT;
if (JWT валиден?) then (да)
    :4.2. Проверка роли администратора;
    if (role = "admin"?) then (да)
        :4.3. Валидация входных параметров;
        if (Валидация прошла успешно?) then (да)
            :4.4. Запрос к БД на получение объявления (без фильтра is_hidden);
            if (Объявление найдено?) then (да)
                :4.5. Запрос к БД на получение информации об источнике;
                :4.6. Запрос к БД на получение фотографий объявления;
                :4.7. Формирование итогового ответа;
                #palegreen :4.8. Отправка ответа об успехе;
                stop
            else (нет)
            endif
        else (нет)
        endif
    else (нет)
    endif
else (нет)
endif
#pink :Отправка ответа об ошибке;
stop
@enduml
