# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# ── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=brandhunt-photos

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_MODEL=gemma3:4b
# OLLAMA_HOST и MINIO_ENDPOINT внутри Docker переопределяются в docker-compose

# ── Telegram ───────────────────────────────────────────────────────────────
TG_API_ID=
TG_API_HASH=
# Строковая сессия (получить: docker compose run --rm --no-deps tg-monitor python auth_tg.py)
TG_SESSION_STRING=
# Прокси SOCKS5 (опционально)
TG_PROXY_HOST=
TG_PROXY_PORT=
TG_PROXY_USER=
TG_PROXY_PASS=
# ID каналов через запятую: -100123456789,-100987654321
TG_WATCHED_CHANNELS=

# ── VK ─────────────────────────────────────────────────────────────────────
VK_ACCESS_TOKEN=
VK_CHECK_INTERVAL=5
# Группы JSON-массивом: [{"id": -225463035, "name": "Название группы"}]
VK_GROUPS=[]
